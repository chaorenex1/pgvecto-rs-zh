# Container/image identity
CONTAINER_NAME=minir-pg
POSTGRES_IMAGE=minir-pg:latest

# Host networking
HOST_PORT=5433

# Database bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_INITDB_ARGS=--data-checksums

# PostgreSQL runtime tuning
POSTGRES_IO_METHOD=worker

# Advanced path overrides inside the container
POSTGRES_CONFIG_FILE=/runtime/postgresql.conf
POSTGRES_FALLBACK_CONFIG_FILE=/etc/postgresql/postgresql.conf
AGENSGRAPH_GRAPH_PATH=/runtime/agensgraph
PGDATA=/runtime/pgdata
